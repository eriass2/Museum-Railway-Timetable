{
  "name": "mrt-vue-public",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.pdf.config.ts && vite build --config vite.admin.config.ts",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "verify": "node scripts/verify-build.mjs",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "check": "npm run typecheck && npm run test && npm run build && npm run verify"
  },
  "dependencies": {
    "html2pdf.js": "^0.10.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.51.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "happy-dom": "^17.6.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.61.0"
  }
}
