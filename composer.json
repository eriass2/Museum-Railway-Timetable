{
    "name": "museum-railway/museum-railway-timetable",
    "description": "WordPress plugin for museum railway timetables",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "wp-coding-standards/wpcs": "^3.0",
        "phpunit/phpunit": "^11.5",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "plugin-check": "php scripts/validate.php",
        "phpstan": "phpstan analyse --memory-limit=1G --no-progress",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "check": ["@plugin-check", "@phpstan", "@test"],
        "check:all": ["@check", "@phpcs"],
        "lint": ["@phpstan", "@phpcs"],
        "test": "@php vendor/bin/phpunit",
        "vue:build": "npm --prefix frontend/vue ci && npm --prefix frontend/vue run build",
        "vue:check": "npm --prefix frontend/vue ci && npm --prefix frontend/vue run check",
        "csv:validate": "php scripts/csv-validate.php",
        "csv:zip": "bash scripts/csv-package-zip.sh"
    }
}
