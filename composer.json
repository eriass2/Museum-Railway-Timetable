{
    "name": "museum-railway/museum-railway-timetable",
    "description": "WordPress plugin for museum railway timetables",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "wp-coding-standards/wpcs": "^3.0",
        "phpunit/phpunit": "^11.5",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "plugin-check": "php scripts/validate.php",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "check": ["@plugin-check", "@phpstan", "@test", "@test:js"],
        "lint": ["@phpstan", "@phpcs"],
        "test": "phpunit",
        "test:js": "node --test tests/js/*.mjs"
    }
}
